#
# Unified integration platform configuration (example).
#

server:
  port: 9000

integration:
  timezone: Asia/Shanghai
  web-root: ../integration-web/dist

runtime:
  base-dir: ..
  bundled-dir: integration-server/bundled
  dolphinscheduler:
    install-dir: runtime/dolphinscheduler
    version: "3.2.2"
  seatunnel-engine:
    install-dir: runtime/seatunnel-engine
    version: "2.3.11"
  seatunnel-web:
    install-dir: runtime/seatunnel-web
    version: "1.0.3-SNAPSHOT"

processes:
  dolphinscheduler:
    enabled: true
    api-url: http://127.0.0.1:12345/dolphinscheduler
    auto-start: true
  seatunnel-engine:
    enabled: true
    auto-start: true
  seatunnel-web:
    enabled: true
    api-url: http://127.0.0.1:8801
    auto-start: true

dolphinscheduler:
  token: ""
  project-code: ""
  username: admin
  password: dolphinscheduler123

seatunnel-web:
  service-token: ""
  jwt-secret: seatunnel-web-jwt-secret-key-2026
  ui-path: /seatunnel-ui

spring:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://127.0.0.1:3306/integration?useSSL=false&serverTimezone=Asia/Shanghai
    username: seatunnel
    password: seatunnel

logging:
  path: ./logs
